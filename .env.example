# ─────────────────────────────────────────────────────────────
# Variables d'environnement Memorabilius
# Copie ce fichier en .env.local (dev) et renseigne les valeurs.
# En PROD/STAGING : configure ces variables dans Vercel (par projet).
# ⚠️ Ne commite JAMAIS de vraies clés.
# ─────────────────────────────────────────────────────────────

# ── Supabase (⚠️ PROD et STAGING doivent pointer vers des projets DIFFÉRENTS) ──
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # secret — jamais exposé côté client

# ── Site ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000   # en staging : l'URL du déploiement de test

# ── Notifications push (Web Push / VAPID) ──
# Générer une paire dédiée au staging : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=contact@memorabilius.fr

# ── IA (détection de coins / scan de carte) ──
GEMINI_API_KEY=

# ── Emails (récap mensuel) ──
RESEND_API_KEY=

# ── Webhook Ko-fi (dons) ──
KOFI_WEBHOOK_TOKEN=

# ── eBay (valeur des cartes) ──
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_VERIFICATION_TOKEN=

# ── Protection des routes cron (Vercel Cron envoie ce secret) ──
CRON_SECRET=
